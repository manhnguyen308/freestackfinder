{{- $pages := where .Site.RegularPages ".Params.noindex" "!=" true -}}
{{- $result := slice -}}
{{- range $pages -}}
  {{- $cat := "" -}}
  {{- with .Params.categories -}}{{- $cat = index . 0 -}}{{- end -}}
  {{- $item := dict "url" .RelPermalink "title" .Title "description" (.Description | default "") "category" $cat "section" .Section "date" (.Date.Format "2006-01-02") "lastmod" (.Lastmod.Format "2006-01-02") -}}
  {{- $result = $result | append $item -}}
{{- end -}}
{{- $result | jsonify -}}
